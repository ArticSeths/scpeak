# ============================================
# SCPeak - Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores.
# Genera secretos seguros con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── PostgreSQL (usado por docker-compose.yml y el servidor) ──
POSTGRES_USER=admin
POSTGRES_PASSWORD=<genera-un-secreto>
POSTGRES_DB=sc_comms_db
DATABASE_URL=postgresql://admin:<misma-password-de-arriba>@localhost:5432/sc_comms_db

# ── JWT ──
JWT_SECRET=<genera-un-secreto>

# ── LiveKit (usado por docker-compose.yml y el servidor) ──
LIVEKIT_API_KEY=<genera-una-api-key>
LIVEKIT_API_SECRET=<genera-un-secreto>
LIVEKIT_URL=ws://localhost:7880

# ── Server ──
PORT=3001
