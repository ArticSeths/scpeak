# ============================================================
# SCPeak - Configuración del Servidor
# ============================================================
# Rellena estos valores y renombra este archivo a .env
#
# Para generar secretos seguros, ejecuta en tu terminal:
#   openssl rand -hex 32
#   (o en Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")

# ── Tu Servidor ──
# Nombre que verán los usuarios al conectarse
SERVER_NAME=Mi Servidor SCPeak

# Contraseña que los usuarios necesitan para registrarse (déjalo vacío para acceso libre)
SERVER_PASSWORD=

# ── Secretos (OBLIGATORIO cambiar) ──
JWT_SECRET=CAMBIA-ESTO-genera-un-secreto-con-openssl-rand-hex-32
LIVEKIT_API_KEY=CAMBIA-ESTO-genera-una-key
LIVEKIT_API_SECRET=CAMBIA-ESTO-genera-un-secreto-con-openssl-rand-hex-32
POSTGRES_PASSWORD=CAMBIA-ESTO-genera-una-password-segura

# ── Avanzado (opcional) ──
# POSTGRES_USER=admin
# POSTGRES_DB=sc_comms_db
# API_PORT=3001
# LIVEKIT_SIGNAL_PORT=7880
# LIVEKIT_TCP_PORT=7881
# LIVEKIT_UDP_PORT=7882
